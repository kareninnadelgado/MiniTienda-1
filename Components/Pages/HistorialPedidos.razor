@page "/historial-pedidos"
@using MiniTienda.Models
@inject MiniTienda.Services.PostgresService postgresService
@inject NavigationManager nav
@rendermode InteractiveServer

<PageTitle>Historial de Pedidos</PageTitle>

<div class="py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Mis Pedidos</h1>
        <a href="/productos" class="btn btn-outline-primary">← Continuar comprando</a>
    </div>

    @if (estaCargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando historial de pedidos...</p>
        </div>
    }
    else if (usuarioSesion == null)
    {
        <div class="alert alert-warning">
            Debes <a href="/login" class="alert-link">iniciar sesión</a> para ver tu historial de pedidos.
        </div>
    }
    else if (tickets == null || !tickets.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <h2 class="h5 mb-3">Aún no tienes pedidos</h2>
                <p class="text-muted mb-4">Comienza a comprar para ver tu historial de pedidos.</p>
                <a href="/productos" class="btn btn-primary">Explorar productos</a>
            </div>
        </div>
    }
    else
    {
        <div class="row gy-4">
            @foreach (var ticket in tickets)
            {
                <div class="col-lg-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div>
                                        <span class="text-muted">Número de pedido:</span>
                                        <span class="fw-bold">#@ticket.IdTicket</span>
                                    </div>
                                    <div class="mt-2">
                                        <span class="text-muted">Fecha:</span>
                                        <span class="fw-bold">@ticket.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <div>
                                        <span class="text-muted">Estado:</span>
                                        <span class="badge bg-success">@ticket.Estado</span>
                                    </div>
                                    <div class="mt-2">
                                        <span class="text-muted">Total:</span>
                                        <span class="h5 text-primary">@ticket.Total.ToString("C")</span>
                                    </div>
                                </div>
                            </div>

                            @if (ticket.Items != null && ticket.Items.Any())
                            {
                                <hr />
                                <h6 class="mb-3">Productos comprados:</h6>
                                
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Producto</th>
                                                <th class="text-end">Precio unitario</th>
                                                <th class="text-center">Cantidad</th>
                                                <th class="text-end">Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in ticket.Items)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold">@item.NombreProducto</div>
                                                        <small class="text-muted">@item.DescripcionProducto</small>
                                                    </td>
                                                    <td class="text-end">@item.PrecioUnitario.ToString("C")</td>
                                                    <td class="text-center">@item.Cantidad</td>
                                                    <td class="text-end">@($"{item.PrecioUnitario * item.Cantidad:C}")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private Usuario? usuarioSesion;
    private List<Ticket>? tickets;
    private bool estaCargando = false;

    protected override void OnInitialized()
    {
        usuarioSesion = postgresService.ObtenerUsuarioActual();
        CargarHistorial();
    }

    private void CargarHistorial()
    {
        estaCargando = true;

        try
        {
            if (usuarioSesion == null)
            {
                tickets = new List<Ticket>();
                return;
            }

            tickets = postgresService.ObtenerTicketsPorUsuario(usuarioSesion.IdUsuario);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar historial: {ex.Message}");
            tickets = new List<Ticket>();
        }
        finally
        {
            estaCargando = false;
        }
    }
}
