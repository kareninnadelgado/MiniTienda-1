@page "/carrito"
@inject NavigationManager nav

<PageTitle>Carrito</PageTitle>

<div class="py-5">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h1 class="h4 mb-3">Carrito de compras</h1>
            <p class="text-muted">Este módulo está reservado para la futura implementación del carrito y la gestión de pedidos.</p>
            <div class="alert alert-info">Aquí se mostrará el resumen de los productos seleccionados, cantidades y el total cuando se integre el carrito.</div>
            <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/productos")'>Volver a productos</button>
        </div>
    </div>
</div>