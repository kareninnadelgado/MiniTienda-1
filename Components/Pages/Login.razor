@page "/login"
@rendermode InteractiveServer
@using MiniTienda.Services
@inject NavigationManager nav
@inject MiniTienda.Services.PostgresService postgresService
@inject FirebaseAuthService authService

<link href="login.css" rel="stylesheet" />

<div class="login-bg">
    <div class="overlay"></div>

    <div class="login-container">

        <h3>Iniciar Sesión</h3>

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="email" placeholder="Ingresa tu correo" />
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            <input type="password" @bind="password" placeholder="Ingresa tu contraseña" />
        </div>

        <button @onclick="IniciarSesion">
            Iniciar Sesión
        </button>

        <button class="register-btn" @onclick='() => nav.NavigateTo("/register")'>
            Registrarte
        </button>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <p>@mensaje</p>
        }

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string mensaje = "";

private async Task IniciarSesion()
    {
        try
        {
            mensaje = "Entrando al método...";

            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
            {
                mensaje = "Completa todos los campos.";
                return;
            }

            mensaje = "Validando Firebase...";
            var resultado = await authService.Login(email, password);

            if (resultado.Contains("idToken"))
            {
                mensaje = "Firebase correcto. Buscando en base de datos...";

                // 1. Buscamos el usuario en MySQL
                var usuario = postgresService.ObtenerUsuarioPorCorreo(email);

                if (usuario != null)
                {
                    // 2. ¡ESTA ES LA PARTE CLAVE! 
                    // Guardamos al usuario en el servicio para que "Productos.razor" pueda verlo
                    postgresService.SetUsuarioActual(usuario);

                    mensaje = $"Bienvenido {usuario.Nombre} - Rol: {usuario.Rol}";

                    // 3. Redirigimos según el rol
                    if (usuario.Rol == "admin")
                    {
                        nav.NavigateTo("/productos");
                    }
                    else
                    {
                        nav.NavigateTo("/"); // Los clientes van al inicio
                    }
                }
                else
                {
                    mensaje = "Usuario autenticado pero no existe en PostgreSQL.";
                }
            }
            else
            {
                mensaje = "Correo o contraseña incorrectos.";
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error: " + ex.Message;
        }
    }
}