@page "/productos"
@using MiniTienda.Models
@inject MiniTienda.Services.PostgresService postgresService
@inject NavigationManager nav
@rendermode InteractiveServer

<PageTitle>Productos</PageTitle>

<div class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Catálogo de Productos</h1>
            <p class="text-muted mb-0">Explora todos nuestros productos y filtra por categoría.</p>
        </div>
        <div class="text-sm-end">
            @if (usuarioSesion != null && usuarioSesion.Rol == "cliente")
            {
                <div class="d-flex gap-2 align-items-center">
                    <span class="badge bg-secondary text-uppercase">Rol: @usuarioSesion.Rol</span>
                    <a href="/carrito" class="btn btn-sm btn-primary">
                        🛒 Mi Carrito
                    </a>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @mensajeExito
            <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }

    <div class="row gy-4">
        <div class="col-lg-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="h5 mb-3">Filtrar</h2>
                    
                    <div class="mb-3">
                        <label class="form-label">Buscar por nombre</label>
                        <input class="form-control" @bind="filtro" placeholder="Ej. leche, pan..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Categoría</label>
                        <select class="form-select" @bind="categoriaFiltro">
                            <option value="">Todas las categorías</option>
                            @foreach (var cat in categoriasDisponibles)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-outline-secondary w-100" @onclick="LimpiarFiltro" disabled="@(string.IsNullOrWhiteSpace(filtro) && string.IsNullOrWhiteSpace(categoriaFiltro))">
                        Limpiar filtros
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            @if (productos == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (productosFiltrados.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var p in productosFiltrados)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title mb-0">@p.Nombre</h5>
                                        <span class="badge bg-secondary">@(!string.IsNullOrEmpty(p.Categoria) ? p.Categoria : "Sin categoría")</span>
                                    </div>
                                    <p class="card-text text-muted mb-3 flex-grow-1">
                                        @(!string.IsNullOrEmpty(p.Descripcion) ? p.Descripcion : "Sin descripción disponible.")
                                    </p>
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="h6 text-primary mb-0">@p.Precio.ToString("C")</span>
                                            <span class="badge @(p.Stock > 0 ? "bg-success" : "bg-danger")">
                                                @(p.Stock > 0 ? "Disponible" : "Agotado")
                                            </span>
                                        </div>
                                        @if (usuarioSesion?.Rol == "cliente")
                                        {
                                            @if (p.Stock > 0)
                                            {
                                                <button class="btn btn-sm btn-primary w-100" 
                                                    @onclick="() => AgregarAlCarrito(p)" 
                                                    disabled="@estaCargando">
                                                    @if (estaCargando)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                    }
                                                    Añadir al carrito
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-secondary w-100" disabled>
                                                    Agotado
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    No se encontraron productos para los criterios seleccionados.
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Usuario? usuarioSesion;
    private List<Producto>? productos;
    private string filtro = string.Empty;
    private string categoriaFiltro = string.Empty;
    private bool estaCargando = false;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    protected override void OnInitialized()
    {
        usuarioSesion = postgresService.ObtenerUsuarioActual();
        productos = postgresService.ObtenerProductos();
    }

    private IEnumerable<Producto> productosFiltrados => (productos ?? new()).AsEnumerable()
        .Where(p => (string.IsNullOrWhiteSpace(filtro) || p.Nombre.Contains(filtro, StringComparison.OrdinalIgnoreCase) || (p.Descripcion?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false))
                 && (string.IsNullOrWhiteSpace(categoriaFiltro) || string.Equals(p.Categoria, categoriaFiltro, StringComparison.OrdinalIgnoreCase)))
        .OrderBy(p => p.Nombre);

    private List<string> categoriasDisponibles => (productos ?? new())
        .Select(p => string.IsNullOrWhiteSpace(p.Categoria) ? "Sin categoría" : p.Categoria!)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(c => c)
        .ToList();

    private void LimpiarFiltro()
    {
        filtro = string.Empty;
        categoriaFiltro = string.Empty;
    }

    private async Task AgregarAlCarrito(Producto producto)
    {
        try
        {
            estaCargando = true;
            mensajeError = string.Empty;
            mensajeExito = string.Empty;

            if (usuarioSesion == null)
            {
                mensajeError = "Debes estar autenticado para agregar productos al carrito.";
                return;
            }

            // Validar stock
            if (!postgresService.ValidarStockDisponible(producto.IdProducto, 1))
            {
                mensajeError = $"Stock insuficiente para {producto.Nombre}";
                return;
            }

            // Obtener o crear carrito activo
            var carrito = postgresService.ObtenerCarritoActivo(usuarioSesion.IdUsuario);
            if (carrito == null)
            {
                carrito = postgresService.CrearCarrito(usuarioSesion.IdUsuario);
            }

            // Agregar al carrito
            postgresService.AgregarAlCarrito(carrito.IdCarrito, producto.IdProducto, 1);

            // Registrar auditoría
            postgresService.RegistrarAuditoria(
                usuarioSesion.IdUsuario,
                "agregar_carrito",
                "producto",
                producto.IdProducto,
                $"{{\"nombre\": \"{producto.Nombre}\", \"precio\": {producto.Precio}}}"
            );

            mensajeExito = $"{producto.Nombre} agregado al carrito correctamente.";
            await Task.Delay(1500);
            mensajeExito = string.Empty;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al agregar al carrito: {ex.Message}";
        }
        finally
        {
            estaCargando = false;
        }
    }
}
