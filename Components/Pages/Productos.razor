@page "/productos"
@using MiniTienda.Models
@using MiniTienda.Services
@inject PostgresService postgresService
@inject NavigationManager nav
@rendermode InteractiveServer

@if (usuarioSesion == null)
{
    <div class="container mt-5 text-center">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Verificando credenciales de administrador...</p>
    </div>
}
else if (usuarioSesion.Rol != "admin")
{
    <div class="container mt-5">
        <div class="alert alert-danger shadow-lg border-0 text-center p-5">
            <i class="bi bi-shield-lock-fill" style="font-size: 4rem;"></i>
            <h2 class="mt-3 fw-bold">Acceso Restringido</h2>
            <p class="lead">Tu cuenta actual (@usuarioSesion.Correo) no tiene permisos de Administrador.</p>
            <hr />
            <p>Solo el encargado del kiosko puede gestionar el inventario de productos.</p>
            <button class="btn btn-danger btn-lg mt-3" @onclick='() => nav.NavigateTo("/")'>
                <i class="bi bi-house-door"></i> Volver al Inicio
            </button>
        </div>
    </div>
}
else
{
    <div class="container mt-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header @(esEdicion ? "bg-warning text-dark" : "bg-primary text-white")">
                <h5 class="mb-0">
                    <i class="bi @(esEdicion ? "bi-pencil-square" : "bi-plus-circle")"></i> 
                    @(esEdicion ? "Modificar Datos del Producto" : "Registrar Nueva Mercancía")
                </h5>
            </div>
            <div class="card-body bg-light">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Nombre del Producto</label>
                        <input type="text" class="form-control" @bind="productoActual.Nombre" placeholder="Ej. Jitomate / Foco / Gelatina" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Categoría y Tipo de Venta</label>
                        <select class="form-select" @bind="productoActual.Categoria">
                            <option value="">Seleccionar...</option>
                            <option value="Frutas y Verduras (Venta por Kilo)">Frutas y Verduras (Kilo)</option>
                            <option value="Abarrotes y Latas">Abarrotes</option>
                            <option value="Dulces y Botanas">Dulces y Botanas</option>
                            <option value="Ferretería (Focos/Pilas)">Ferretería</option>
                            <option value="Desechables y Plásticos">Desechables</option>
                            <option value="Repostería (Gelatinas/Harina)">Repostería</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Precio ($)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" @bind="productoActual.Precio" step="0.50" />
                        </div>
                        <small class="text-muted">@(productoActual.Categoria?.Contains("Kilo") == true ? "Precio por KG" : "Precio por Pieza")</small>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Cantidad / Peso</label>
                        <input type="number" class="form-control" @bind="productoActual.Stock" />
                        <small class="text-muted">@(productoActual.Categoria?.Contains("Kilo") == true ? "Kilos actuales" : "Piezas en estante")</small>
                    </div>
                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button class="btn @(esEdicion ? "btn-warning" : "btn-success") w-100 fw-bold shadow-sm" @onclick="Guardar">
                            <i class="bi bi-check-lg"></i> @(esEdicion ? "Aplicar" : "Guardar")
                        </button>
                        @if (esEdicion)
                        {
                            <button class="btn btn-secondary shadow-sm" @onclick="Cancelar" title="Cancelar edición">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio Sugerido</th>
                            <th>Existencia</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (productos != null && productos.Any())
                        {
                            @foreach (var p in productos)
                            {
                                <tr>
                                    <td class="align-middle fw-bold">@p.Nombre</td>
                                    <td class="align-middle"><span class="badge rounded-pill bg-info text-dark">@p.Categoria</span></td>
                                    <td class="align-middle">@p.Precio.ToString("C") @(p.Categoria?.Contains("Kilo") == true ? "x KG" : "c/u")</td>
                                    <td class="align-middle text-center">
                                        <span class="fw-bold @(p.Stock < 5 ? "text-danger" : "text-dark")">@p.Stock</span> 
                                        @(p.Categoria?.Contains("Kilo") == true ? " kg" : " pzas")
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => PrepararEditar(p)">
                                            <i class="bi bi-pencil">Editar</i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Borrar(p.IdProducto)">
                                            <i class="bi bi-trash">Eliminar</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted italic">
                                    No hay mercancía registrada en el inventario.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private Usuario? usuarioSesion;
    private List<Producto>? productos;
    private Producto productoActual = new();
    private bool esEdicion = false;

    protected override async Task OnInitializedAsync()
    {
        // En tu proyecto, este método consulta MySQL para validar el rol
        usuarioSesion = await Task.FromResult(postgresService.ObtenerUsuarioActual()); 
        
        if (usuarioSesion?.Rol == "admin") 
        {
            Cargar();
        }
    }

    private void Cargar() => productos = postgresService.ObtenerProductos();

    private void Guardar()
    {
        if (string.IsNullOrWhiteSpace(productoActual.Nombre)) return;

        if (esEdicion) 
            postgresService.ActualizarProducto(productoActual);
        else 
            postgresService.InsertarProducto(productoActual);
        
        Cancelar();
        Cargar();
    }

    private void PrepararEditar(Producto p)
    {
        // Creamos una copia para no editar directamente la fila de la tabla antes de guardar
        productoActual = new Producto {
            IdProducto = p.IdProducto,
            Nombre = p.Nombre,
            Descripcion = p.Descripcion,
            Precio = p.Precio,
            Stock = p.Stock,
            Categoria = p.Categoria
        };
        esEdicion = true;
    }

    private void Cancelar()
    {
        productoActual = new();
        esEdicion = false;
    }

    private void Borrar(int id)
    {
        postgresService.EliminarProducto(id);
        Cargar();
    }
}